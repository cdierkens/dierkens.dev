{
  "name": "dierkens.dev",
  "private": false,
  "description": "Blog for Dierkens the Dev",
  "version": "0.1.0",
  "author": "Christopher Dierkens <cjdierkens@gmail.com.com>",
  "scripts": {
    "start": "gatsby develop",
    "check": "tsc --noEmit",
    "lint": "eslint src --ext ts,tsx",
    "build": "gatsby build",
    "serve": "gatsby serve",
    "test": "jest --watch",
    "test:ci": "jest",
    "deploy": "aws s3 cp public s3://dierkens.dev --recursive"
  },
  "dependencies": {
    "@hot-loader/react-dom": "16.13.0",
    "@mdx-js/mdx": "1.6.18",
    "@mdx-js/react": "1.6.18",
    "@types/mdx-js__react": "1.5.2",
    "@types/react": "16.9.49",
    "@types/react-dom": "16.9.8",
    "autoprefixer": "9.8.6",
    "cssnano": "4.1.10",
    "eslint": "7.9.0",
    "eslint-config-react-app": "5.2.1",
    "eslint-loader": "4.0.2",
    "eslint-plugin-flowtype": "5.2.0",
    "eslint-plugin-import": "2.22.0",
    "eslint-plugin-jsx-a11y": "6.3.1",
    "eslint-plugin-react": "7.21.1",
    "eslint-plugin-react-hooks": "4.1.2",
    "gatsby": "2.24.65",
    "gatsby-image": "2.4.19",
    "gatsby-plugin-eslint": "2.0.8",
    "gatsby-plugin-mdx": "1.2.41",
    "gatsby-plugin-offline": "3.2.28",
    "gatsby-plugin-postcss": "2.3.12",
    "gatsby-plugin-prefetch-google-fonts": "1.4.3",
    "gatsby-plugin-sass": "2.3.13",
    "gatsby-plugin-typescript": "2.4.20",
    "gatsby-remark-prismjs": "3.5.13",
    "gatsby-source-filesystem": "2.3.30",
    "gatsby-transformer-remark": "2.8.35",
    "node-sass": "4.14.1",
    "prismjs": "1.21.0",
    "react": "16.13.1",
    "react-dom": "16.13.1",
    "tailwindcss": "1.8.10",
    "typescript": "4.0.3"
  },
  "devDependencies": {
    "@babel/preset-typescript": "7.10.4",
    "@testing-library/jest-dom": "5.11.4",
    "@testing-library/react": "11.0.4",
    "babel-jest": "26.3.0",
    "babel-preset-gatsby": "0.5.10",
    "concurrently": "5.3.0",
    "husky": "4.3.0",
    "identity-obj-proxy": "3.0.0",
    "inquirer-fuzzy-path": "2.3.0",
    "jest": "26.4.2",
    "lint-staged": "10.4.0",
    "plop": "2.7.4",
    "prettier": "2.1.2",
    "stylelint": "13.7.1",
    "stylelint-config-recommended": "3.0.0"
  },
  "keywords": [
    "gatsby",
    "typescript",
    "tailwind",
    "tailwind css",
    "starter"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/impulse/gatsby-typescript-tailwind"
  },
  "bugs": {
    "url": "https://github.com/impulse/gatsby-typescript-tailwind/issues"
  },
  "husky": {
    "hooks": {
      "pre-commit": "lint-staged"
    }
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx}": [
      "prettier --write",
      "eslint --fix"
    ],
    "*.{json,md}": [
      "prettier --write"
    ]
  }
