    "babel-jest": "25.1.0",
    "babel-preset-gatsby": "0.3.0",
    "concurrently": "5.1.0",
    "husky": "4.2.3",
    "identity-obj-proxy": "3.0.0",
    "inquirer-fuzzy-path": "2.2.0",
    "jest": "25.1.0",
    "lint-staged": "10.0.8",
    "plop": "2.6.0",
    "prettier": "2.0.2",
    "stylelint": "13.2.1",
    "stylelint-config-recommended": "3.0.0"
