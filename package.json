{
  "name": "dierkens.dev",
  "private": true,
  "description": "Blog for Dierkens the Dev",
  "version": "0.1.0",
  "author": "Christopher Dierkens <cjdierkens@gmail.com>",
  "scripts": {
    "start": "gatsby develop",
    "check": "tsc --noEmit",
    "lint": "eslint src --ext ts,tsx",
    "build": "gatsby build",
    "serve": "gatsby serve",
    "test": "jest --watch",
    "test:ci": "jest",
    "deploy": "npm run sync && npm run invalidate",
    "sync": "aws s3 sync public s3://dierkens-dev-static-assets-production --delete",
    "invalidate": "aws cloudfront create-invalidation --distribution-id EXVDLIG8FU5J6 --paths \"/*\" --no-cli-pager",
    "postinstall": "husky install"
  },
  "dependencies": {
    "@hot-loader/react-dom": "17.0.1",
    "@mdx-js/mdx": "1.6.22",
    "@mdx-js/react": "1.6.22",
    "@tailwindcss/typography": "0.4.1",
    "@types/mdx-js__react": "1.5.5",
    "@types/react": "17.0.37",
    "@types/react-dom": "17.0.11",
    "autoprefixer": "10.4.0",
    "cssnano": "5.0.12",
    "date-fns": "2.27.0",
    "eslint": "7.32.0",
    "eslint-config-react-app": "6.0.0",
    "eslint-loader": "4.0.2",
    "eslint-plugin-flowtype": "5.10.0",
    "eslint-plugin-import": "2.25.3",
    "eslint-plugin-jsx-a11y": "6.5.1",
    "eslint-plugin-react": "7.27.1",
    "eslint-plugin-react-hooks": "4.3.0",
    "eslint-webpack-plugin": "2.6.0",
    "gatsby": "3.14.6",
    "gatsby-image": "3.11.0",
    "gatsby-plugin-client-side-redirect": "1.1.0",
    "gatsby-plugin-eslint": "3.0.0",
    "gatsby-plugin-mdx": "2.14.0",
    "gatsby-plugin-offline": "4.14.0",
    "gatsby-plugin-postcss": "4.14.0",
    "gatsby-plugin-react-head": "1.1.0",
    "gatsby-plugin-s3": "0.3.8",
    "gatsby-plugin-typescript": "3.14.0",
    "gatsby-plugin-webfonts": "2.2.1",
    "gatsby-remark-prismjs": "5.11.0",
    "gatsby-source-filesystem": "3.14.0",
    "gatsby-transformer-remark": "4.11.0",
    "postcss": "8.4.4",
    "postcss-import": "14.0.2",
    "prismjs": "1.24.1",
    "react": "17.0.2",
    "react-dom": "17.0.2",
    "react-head": "3.4.0",
    "tailwindcss": "2.2.19",
    "typescript": "4.5.2"
  },
  "devDependencies": {
    "@babel/core": "7.16.0",
    "@babel/preset-typescript": "7.16.0",
    "@testing-library/jest-dom": "5.16.1",
    "@testing-library/react": "11.2.7",
    "babel-eslint": "10.1.0",
    "babel-jest": "27.3.1",
    "babel-preset-gatsby": "1.14.0",
    "concurrently": "6.4.0",
    "husky": "6.0.0",
    "identity-obj-proxy": "3.0.0",
    "inquirer-fuzzy-path": "2.3.0",
    "jest": "27.3.1",
    "lint-staged": "11.2.6",
    "mockdate": "3.0.5",
    "pinst": "2.1.6",
    "plop": "2.7.6",
    "prettier": "2.5.1",
    "stylelint": "14.2.0",
    "stylelint-config-recommended": "5.0.0"
  },
  "keywords": [
    "gatsby",
    "typescript",
    "tailwind",
    "tailwind css",
    "starter"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/impulse/gatsby-typescript-tailwind"
  },
  "bugs": {
    "url": "https://github.com/impulse/gatsby-typescript-tailwind/issues"
  },
  "husky": {
    "hooks": {
      "pre-commit": "lint-staged"
    }
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx}": [
      "prettier --write",
      "eslint --fix"
    ],
    "*.{json,md}": [
      "prettier --write"
    ]
  }
}
