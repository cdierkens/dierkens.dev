    "autoprefixer": "9.7.5",
    "cssnano": "4.1.10",
    "eslint": "6.8.0",
    "eslint-config-react-app": "5.2.1",
    "eslint-loader": "3.0.3",
    "eslint-plugin-flowtype": "4.6.0",
    "eslint-plugin-import": "2.20.1",
    "eslint-plugin-jsx-a11y": "6.2.3",
    "eslint-plugin-react": "7.19.0",
    "eslint-plugin-react-hooks": "2.5.1",
    "gatsby": "2.20.2",
    "gatsby-image": "2.3.0",
    "gatsby-plugin-eslint": "2.0.8",
